{
  "ConnectionStrings": {
    "FishDexDb": "Host=localhost;Port=5433;Database=fishdex;Username=fishdex;Password=fishdex_local_pwd"
  },
  "JwtSettings": {
    "SecretKey": "YourVeryLongSecretKeyThatShouldBeAtLeast32CharactersLong!",
    "Issuer": "FishLover",
    "Audience": "FishLover",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "FishDex.API",
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AuthServer": {
    "Url": "http://localhost:8080",
    "Authority": "http://localhost:8080"
  },
  "AllowedHosts": "*",
  "FishDexSettings": {
    "LanguageTopCount": 10
  },
  "Storage": {
    "Provider": "minio",
    "ServiceUrl": "http://localhost:9000",
    
    
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "system-image",
    "PresignedUrlExpiryMinutes": 60,
    "ForcePathStyle": true
  }
}