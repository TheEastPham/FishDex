{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FishLover_Auth;Trusted_Connection=true;MultipleActiveResultSets=true",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "YourVeryLongSecretKeyThatShouldBeAtLeast32CharactersLong!",
    "Issuer": "UserManagement",
    "Audience": "Client",
    "ExpiryMinutes": "60"
  },
  "ClientConfigurations": [
    {
      "ClientId": "AquaDex_Web",
      "RedirectUrl": "https://localhost:3000/callback",
      "Description": "Hệ thống quản lý bể cá"
    },
    {
      "ClientId": "FishDex_Mobile",
      "RedirectUrl": "fishdex://auth",
      "Description": "Tra cứu từ điển cá"
    }
  ],
  "OpenTelemetry": {
    "ServiceName": "FishLover.Auth.API",
    "ServiceVersion": "1.0.0",
    "ExportEndpoint": "http://localhost:4317",
    "Tracing": {
      "Enabled": true
    },
    "Metrics": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/auth-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}