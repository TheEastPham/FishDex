# PostgreSQL
POSTGRES_USER=fishdex
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=fishdex

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@fishdex.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# FishDex API — ASP.NET Core config overrides
FISHDEX_DB_CONN=Host=fishdex-db;Port=5432;Database=fishdex;Username=fishdex;Password=your_db_password
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars
JWT_ISSUER=FishLover
JWT_AUDIENCE=FishLover
JWT_EXPIRY_MINUTES=60

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
