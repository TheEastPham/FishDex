# Copy thành .env trước khi docker compose up
# Các giá trị này được Vite inline tại BUILD TIME — không dùng environment: trong compose

VITE_AUTH_ISSUER=http://localhost:8080
VITE_AUTH_CLIENT_ID=aquahome-web
VITE_AUTH_REDIRECT_URI=http://localhost:3000/callback
VITE_AUTH_POST_LOGOUT_URI=http://localhost:3000
VITE_AQUAHOME_API_URL=http://localhost:8082
VITE_FISHDEX_API_URL=http://localhost:8081
