# SQL Server
SA_PASSWORD=your_sa_password

# UserManagement API — ASP.NET Core config overrides
UM_DB_CONN=Server=usermanagement-db,1433;Database=UserManagement;User Id=sa;Password=your_sa_password;TrustServerCertificate=True;
REDIS_CONN=usermanagement-redis:6379

JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars
JWT_ISSUER=FishLover
JWT_AUDIENCE=FishLover
JWT_EXPIRY_DAYS=7

SEED_INITIAL_ADMIN=true

EMAIL_API_KEY=re_your_resend_api_key
REQUIRE_INVITATION=false

INITIAL_ADMIN_EMAIL=admin@fishlover.local
INITIAL_ADMIN_PASSWORD=your_admin_password
